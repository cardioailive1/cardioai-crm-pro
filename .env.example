# ─── Cardio AI CRM Pro — environment configuration ───
# Copy to .env for local development:  cp .env.example .env

# Server
NODE_ENV=development
PORT=3000
# Public base URL. On Render this is auto-detected from RENDER_EXTERNAL_URL.
# Locally, leave as-is so OAuth redirects back to your machine.
BASE_URL=http://localhost:3000

# Session signing secret (use a long random string in production)
SESSION_SECRET=dev-only-change-me

# ─── Database ───
# When set, the app uses PostgreSQL. When unset, it falls back to a local
# data.json file so you can run with zero setup.
# Local example:  postgres://postgres:postgres@localhost:5432/cardio_ai_crm
# DATABASE_URL=

# ─── Google Workspace SSO ───
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console.
# Authorized redirect URI must be:  <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to <BASE_URL>/auth/google/callback
# GOOGLE_CALLBACK_URL=

# Restrict sign-in to your company domain(s) (comma-separated)
ALLOWED_EMAIL_DOMAIN=cardioailive.com
# Optional explicit per-email allow-list (overrides the domain check)
# ALLOWED_EMAILS=advisor@gmail.com,contractor@outlook.com

# ─── AI Assistant (server-side proxy) ───
# The assistant calls Anthropic from the server so the key is never in the browser.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Ecosystem integration (Operations hub + Sales Engine) ───
# Shared secret — set the SAME value on every Cardio AI service that exchanges
# pipeline data. Enables this CRM's outbound /api/integrations/pipeline endpoint
# (so the Operations hub can pull CRM deals) and inbound pulls below.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_API_KEY=

# Optional upstreams to pull read-only deals FROM (shown merged in the Pipeline).
# Leave blank to keep the integration outbound-only.
SALES_ENGINE_URL=https://cardioai-sales-platform.onrender.com
# Leave OPERATIONS_URL unset unless you understand the aggregation topology
# (the ops hub already aggregates downstream — pulling it back causes re-imports).
# OPERATIONS_URL=https://cardioai-operations-3ejs.onrender.com
# Set true only to make this CRM a single aggregated source for the ops hub:
# INTEGRATION_EXPORT_EXTERNAL=false
# INTEGRATION_CACHE_MS=60000
